# Copy this file to .env and fill in your real PrivateEmail details.
# Do not commit .env. It is already ignored by Git.

SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@email.co.uk
SMTP_PASS=your_privateemail_password
OUTREACH_FROM="Quaerens <your@email.co.uk>"
OUTREACH_SIGNATURE_NAME=Your name
